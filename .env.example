# UniFi connection
UNIFI_HOST=https://192.168.1.1
UNIFI_API_KEY=replace-me-with-key-from-unifi-settings-integrations
UNIFI_SITE_ID=default
UNIFI_VERIFY_SSL=true

# AdGuard Home connection
ADGUARD_HOST=http://192.168.10.11:3000
ADGUARD_USER=admin
ADGUARD_PASSWORD=replace-me

# Sync behavior
SYNC_SCOPE=fixed
SYNC_INTERVAL_SECONDS=300
DELETE_GRACE_HOURS=24
DRY_RUN=false
MODE=loop

# Infrastructure MACs to skip entirely (comma-separated; lowercase or mixed case OK).
# Useful for excluding the host VM, hypervisor, or any device that lives in UniFi
# but doesn't belong in AdGuard's per-client list.
EXCLUDE_MACS=

# Advanced (usually leave alone)
OWNERSHIP_TAG=managed-by-unifi-sync
LOG_LEVEL=info
TZ=America/Toronto
